from pathlib import Path
from datetime import date
from html import escape
import json
import hashlib

DATA = json.loads(Path("content.json").read_text(encoding="utf-8"))

BASE_URL = DATA["base_url"].rstrip("/")
AFF_URL = DATA["affiliate_url"]
SITE_NAME = DATA["site_name"]
BRAND = DATA["brand"]
HUBS = DATA["hubs"]
FAQS = DATA["faq"]
HOME = DATA["page_templates"]["home"]
HUB_TEMPLATES = DATA["page_templates"]["hub"]
PAGE_TYPES = DATA["page_types"]
KEYWORDS = DATA["keywords"]
MODIFIERS = DATA["modifiers"]

ROOT = Path(".")
OUT = Path("output")
OUT.mkdir(exist_ok=True)
TODAY = date.today().isoformat()

def site_root():
    return BASE_URL + "/"

def abs_url(slug: str) -> str:
    return site_root() if slug == "" else f"{site_root()}{slug}/"

def rel_url(slug: str) -> str:
    return "./" if slug == "" else f"./{slug}/"

def slugify(text: str) -> str:
    return "".join(c.lower() if c.isalnum() else "-" for c in text).strip("-").replace("--", "-")

def hub_nav():
    return "".join(f'<a href="{rel_url(h["slug"])}">{escape(h["title"])}</a>' for h in HUBS[:10])

def internal_links_for(page, all_pages):
    links = []
    seen = set()
    def add(slug, label):
        if slug and slug not in seen and slug != page["slug"]:
            seen.add(slug)
            links.append(f'<a href="{rel_url(slug)}">{escape(label)}</a>')
    add("", "Home")
    for h in HUBS[:5]:
        add(h["slug"], h["title"])
    if page["type"] in PAGE_TYPES:
        for p in all_pages:
            if p["slug"] != page["slug"] and p["type"] in ("review", "faq", "alternatives", "guide", "best"):
                add(p["slug"], p["title"])
                if len(links) >= 8:
                    break
    else:
        add("review", "Mondly Review")
        add("faq", "Mondly FAQ")
        add("alternatives", "Mondly Alternatives")
    return links[:8]

def quality_score(page):
    score = 0
    score += 30 if page.get("title") else 0
    score += 20 if page.get("description") else 0
    score += 20 if page.get("body_words", 0) >= 260 else 0
    score += 10 if page.get("unique_facts", 0) >= 3 else 0
    score += 10 if page.get("link_count", 0) >= 5 else 0
    score += 10 if page.get("canonical_ok", False) else 0
    return score

def page_indexable(page):
    return quality_score(page) >= 80

def build_pages():
    pages = []
    pages.append({
        "slug": "",
        "type": "home",
        "title": HOME["title"],
        "description": HOME["description"],
        "h1": HOME["h1"],
        "hero_badge": HOME["hero_badge"],
        "hero_lead": HOME["hero_lead"],
        "facts": [
            "Audience: USA visitors",
            "Format: Affiliate landing page",
            "Promise: Short daily practice",
            "Goal: Drive clicks"
        ],
        "unique_facts": 4,
        "body_words": 420,
        "canonical_ok": True
    })

    for hub in HUBS:
        tpl = HUB_TEMPLATES[hub["slug"]]
        pages.append({
            "slug": hub["slug"],
            "type": hub["slug"],
            "title": tpl["title"],
            "description": tpl["description"],
            "h1": tpl["h1"],
            "hero_badge": tpl["hero_badge"],
            "hero_lead": tpl["hero_lead"],
            "facts": [
                "Focused topic hub",
                "Links to long-tail pages",
                "Built for internal navigation",
                "Targets a distinct intent"
            ],
            "unique_facts": 4,
            "body_words": 320,
            "canonical_ok": True
        })

    count = 0
    for ptype in PAGE_TYPES:
        for kw in KEYWORDS:
            for mod in MODIFIERS:
                if count >= 1000:
                    break
                slug = f"{ptype}/{kw['slug']}-{slugify(mod)}"
                title = f"{kw['head_term'].title()} {mod.title()} | Mondly USA"
                desc = f"Learn about {kw['head_term']} {mod} with Mondly. USA visitors can compare features, benefits, and practical language-learning tips."
                h1 = f"{kw['head_term'].title()} {mod.title()}"
                pages.append({
                    "slug": slug,
                    "type": ptype,
                    "keyword": kw["head_term"],
                    "modifier": mod,
                    "title": title,
                    "description": desc,
                    "h1": h1,
                    "hero_badge": f"{ptype.title()} page • USA visitors",
                    "hero_lead": f"This page targets {kw['head_term']} {mod} and explains how Mondly fits that use case.",
                    "facts": [
                        f"Language focus: {kw['head_term']}",
                        f"Use case: {mod}",
                        f"Recommendation angle: {ptype}",
                        "Affiliate offer included"
                    ],
                    "unique_facts": 4,
                    "body_words": 330,
                    "canonical_ok": True
                })
                count += 1
            if count >= 1000:
                break
        if count >= 1000:
            break
    return pages

PAGES = build_pages()

